{
  "name": "mergesafe",
  "version": "1.0.0",
  "private": true,
  "description": "MergeSafe — evidence-based verification for agent-generated pull requests.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @mergesafe/api && npm run build -w @mergesafe/web",
    "db:migrate": "npm run db:migrate -w @mergesafe/api",
    "test": "npm run test -w @mergesafe/api",
    "test:unit": "npm run test:unit -w @mergesafe/api",
    "test:integration": "npm run test:integration -w @mergesafe/api",
    "start:api": "npm run start -w @mergesafe/api",
    "build:web": "npm run build -w @mergesafe/web"
  }
}
